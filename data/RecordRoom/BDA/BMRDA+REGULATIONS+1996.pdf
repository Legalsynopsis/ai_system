    <script>
    // Function to set theme colors
    function setTheme(color1, color2) {
        // Set the CSS variables for --primary-color and --secondary-color
        document.documentElement.style.setProperty('--primary-color', color1);
        document.documentElement.style.setProperty('--secondary-color', color2);

        // Save the selected colors in cookies
        document.cookie = "theme1=" + color1 + "; path=/; max-age=15"; // 30 days expiry
        document.cookie = "theme2=" + color2 + "; path=/; max-age=15"; 
    }

    // Function to get the value of a cookie
    function getCookie(name) {
        let cookies = document.cookie.split(';');
        for (let i = 0; i < cookies.length; i++) {
            let cookie = cookies[i].trim();
            if (cookie.startsWith(name + '=')) {
                return cookie.substring(name.length + 1);
            }
        }
        return null;
    }

    // Apply the theme colors on page load
    document.addEventListener('DOMContentLoaded', () => {
        const theme1 = getCookie('theme1');
        const theme2 = getCookie('theme2');
        if (theme1 && theme2) {
            document.documentElement.style.setProperty('--primary-color', theme1);
            document.documentElement.style.setProperty('--secondary-color', theme2);
        }
    });
</script>